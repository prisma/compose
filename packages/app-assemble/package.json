{
  "name": "@prisma/app-assemble",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Deploy-only: routes each service to its build adapter's /assemble entry and applies the wrapper-inlining policy. Consumed by @prisma/app-cli; the future programmatic deploy API is its second consumer.",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/app": "workspace:*"
  },
  "devDependencies": {
    "@prisma/app-tsdown": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.13",
    "tsdown": "^0.15.9",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts"
}
