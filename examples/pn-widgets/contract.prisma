// use prisma-next
//
// The pn-widgets data contract, authored in PSL. One model — a Widget with a
// uuid id and a text label. `prisma-next contract emit` turns this into
// contract.json (data the runtime + deploy read) and contract.d.ts (the
// branded types the service's typed client flows from).

model Widget {
  id    String @id @default(uuid(4))
  label String

  @@map("Widget")
}
