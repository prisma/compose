# Provisioning credentials for Alchemy deploys against Prisma Cloud.
#
# Copy this to `.env` (gitignored) and fill it in, then pass it to the CLI:
#   alchemy deploy --env-file <repo-root>/.env
#
# Our providers read these from the environment (PrismaCredentials.fromEnv);
# there is no `alchemy login` step for Prisma yet.

# Prisma Management API service token (workspace-scoped; sent as `Authorization: Bearer`).
# Prisma Console (https://console.prisma.io) → your workspace → Settings → Service Tokens
#   → New Service Token → copy it (shown only once).
PRISMA_SERVICE_TOKEN=

# The workspace that will own provisioned projects.
# Find it in the Console URL, or GET https://api.prisma.io/v1/workspaces with the token.
PRISMA_WORKSPACE_ID=

# Any stable random secret — encrypts secrets in Alchemy's local state store.
# MUST stay constant across runs, or existing state can't be decrypted.
ALCHEMY_PASSWORD=
